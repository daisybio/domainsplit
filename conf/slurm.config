/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    daisybio/domainsplit — slurm executor profile
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Picked up via `-profile slurm`. Pair with `singularity` on the cluster
    (the head node norm.exbio has no docker group; singularity user-NS works).
----------------------------------------------------------------------------*/

workDir = '/nfs/scratch/domainsplit/work'

// Allow re-runs to overwrite stale execution_*.html / trace files instead of
// aborting with FileAlreadyExistsException.
report   { overwrite = true }
timeline { overwrite = true }
trace    { overwrite = true }
dag      { overwrite = true }

executor {
    name                = 'slurm'
    queueSize           = 20
    submitRateLimit     = '10/1min'
    pollInterval        = '30s'
}

process {
    executor      = 'slurm'
    cpus          = { 2     * task.attempt }
    memory        = { 12.GB * task.attempt }
    time          = { 4.h   * task.attempt }

    // Retry on transient slurm/oom/socket errors AND on docker/pull/network exit codes
    errorStrategy = { task.exitStatus in [104, 126, 127, 137, 139, 140, 143, 247] ? 'retry' : 'finish' }
    maxRetries    = 3

    withLabel: 'process_low' {
        cpus   = { 2     * task.attempt }
        memory = { 12.GB * task.attempt }
        time   = { 4.h   * task.attempt }
    }
    withLabel: 'process_medium' {
        cpus   = { 6     * task.attempt }
        memory = { 36.GB * task.attempt }
        time   = { 8.h   * task.attempt }
    }
    withLabel: 'process_high' {
        cpus   = { 12    * task.attempt }
        memory = { 72.GB * task.attempt }
        time   = { 16.h  * task.attempt }
    }
    withLabel: 'process_long' {
        time   = { 20.h  * task.attempt }
    }
    withLabel: 'process_high_memory' {
        memory = { 200.GB * task.attempt }
    }

    // ------- GPU -------
    // ESM embeddings: large model + long runtime. Same nodelist as
    // sibling domainbenchmark pipeline. compms-gpu-1 excluded (ECC issues).
    withLabel: 'process_gpu_large' {
        queue          = 'shared-gpu'
        cpus           = { 4      * task.attempt }
        memory         = { 60.GB  * task.attempt }
        time           = { 24.h   * task.attempt }
        clusterOptions = '--gpus-per-task=1 --ntasks=1 --qos=limitgpus --nodelist=jlab-gpu01.exbio.wzw.tum.de,gpu02.exbio.wzw.tum.de,compms-gpu-2.exbio.wzw.tum.de'
        maxForks       = 6
    }
    withLabel: 'process_gpu_small' {
        queue          = 'shared-gpu'
        cpus           = { 2      * task.attempt }
        memory         = { 20.GB  * task.attempt }
        time           = { 12.h   * task.attempt }
        clusterOptions = '--gpus-per-task=1 --ntasks=1 --qos=limitgpus --nodelist=jlab-gpu01.exbio.wzw.tum.de,gpu02.exbio.wzw.tum.de,compms-gpu-2.exbio.wzw.tum.de'
        maxForks       = 6
    }
    withLabel: 'process_gpu' {
        queue          = 'shared-gpu'
        cpus           = { 2      * task.attempt }
        memory         = { 20.GB  * task.attempt }
        time           = { 12.h   * task.attempt }
        clusterOptions = '--gpus-per-task=1 --ntasks=1 --qos=limitgpus --nodelist=jlab-gpu01.exbio.wzw.tum.de,gpu02.exbio.wzw.tum.de,compms-gpu-2.exbio.wzw.tum.de'
        maxForks       = 6
    }

    // ------- per-process overrides -------
    // Batched Pfam alignment downloads (params.pfam_download_batch_size IDs per job).
    // Each job uses threaded I/O internally; keep SLURM concurrency moderate.
    withName: '.*:CURATE_DOMAINS:DOWNLOAD_PFAM_ALIGNMENTS_BATCH' {
        cpus          = 2
        memory        = 4.GB
        time          = 1.h
        maxForks      = 20
        maxRetries    = 3
        errorStrategy = { task.attempt <= 3 ? 'retry' : 'ignore' }
    }

    // ESM embedding chunk processes (per-shard, batched bf16 ESM3+ESMC).
    // Cluster QoS caps concurrent GPU jobs at 4 across the user account, so
    // maxForks=4 here is the local mirror of that. The shared HF cache is
    // set via `params.esm_hf_cache_dir` (see below) so the parallel chunks
    // do not each re-download the gated model from HuggingFace.
    withName: '.*:GENERATE_PROTEIN_ESM_EMBEDDINGS_CHUNK' {
        maxForks = 4
    }
    withName: '.*:GENERATE_DOMAIN_ESM_EMBEDDINGS_CHUNK' {
        maxForks = 4
    }
}

// Shared HF cache on NFS. The chunk processes export this as HF_HOME so all
// parallel GPU tasks read the gated ESM3 / ESMC weights from a single
// pre-populated location. Avoids 4 concurrent gated downloads (rate limits +
// duplicated ~12 GB).
params.esm_hf_cache_dir = '/nfs/scratch/hf_cache'

singularity {
    enabled    = true
    autoMounts = true
    cacheDir   = '/nfs/scratch/singularity_cache'
    runOptions = '--nv'
    envWhitelist = 'HF_TOKEN,HF_HOME,HUGGINGFACE_HUB_CACHE,PYTORCH_CUDA_ALLOC_CONF'
}

conda {
    enabled = false
}

docker {
    enabled = false
}
