# Copy this file to .env and fill in your values.
# The .env file is gitignored and must never be committed.
#
# Usage with Nextflow (recommended):
#   nextflow secrets set HF_TOKEN <your_token>
#   or export HF_TOKEN before running the pipeline.
#
# Usage on a SLURM cluster:
#   Add `export HF_TOKEN=...` to your job script or ~/.bashrc.

# HuggingFace access token — required for downloading ESM model weights.
# Obtain at: https://huggingface.co/settings/tokens
HF_TOKEN=
